{
  "_comment": "Dart OTel Demo — Service Overview dashboard. Demo-specific RED metrics; advanced multi-environment dashboards are a Pro feature.",
  "annotations": {
    "list": []
  },
  "description": "RED metrics for the Dart OTel Demo: request rate, error rate, and request duration per service. The latency-distribution heatmap is the headline panel — it shows the bimodal pattern produced by cache hits (fast tier) and Open-Meteo round trips (slow tier).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Overview",
      "type": "row"
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Total requests (window)",
      "description": "Total HTTP server requests across all services in the selected time window. Counts everything the otelMiddleware histogram saw — successes, errors, and admin endpoints alike.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_server_request_duration_seconds_count[$__range]))",
          "legendFormat": "requests",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "decimals": 0,
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Error rate %",
      "description": "Percentage of requests that returned a 5xx in the selected time window. 4xx codes are caller-attributable and intentionally excluded — see weather_api/lib/src/router.dart for the status mapping.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_request_duration_seconds_count[5m])), 1)",
          "legendFormat": "error %",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 5 }
            ]
          },
          "decimals": 2,
          "unit": "percent"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "p95 latency (window)",
      "description": "95th-percentile request duration across all services, computed from the Prometheus histogram with histogram_quantile. Includes both cache hits (fast) and cache misses + open-meteo round trips (slow).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red",    "value": 2 }
            ]
          },
          "decimals": 3,
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Active services",
      "description": "Number of distinct service.name values currently emitting metrics. Should be 2 (weather-api + cache-service) when the local stack is up and receiving traffic.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "count(count by (service_name) (http_server_request_duration_seconds_count))",
          "legendFormat": "services",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "decimals": 0,
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "panels": [],
      "title": "Per-service",
      "type": "row"
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Request rate per service / route",
      "description": "Requests per second, broken out by service.name and http.route. Series legend uses the LOW-cardinality route TEMPLATE ('/weather/:city'), not the concrete path — the metric labels are intentionally bounded so this query stays fast at scale.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name, http_route) (rate(http_server_request_duration_seconds_count[1m]))",
          "legendFormat": "{{service_name}} {{http_route}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "req/s",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Latency p50 / p95 / p99 per service",
      "description": "Three quantiles per service, computed from the histogram_bucket series. p50 should sit close to the cache-hit floor; p95 and p99 capture the long tail from open-meteo round trips. Diverging p50 and p99 is the signature of a bimodal cache workload.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "refId": "p50",
          "expr": "histogram_quantile(0.50, sum by (service_name, le) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{service_name}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "p95",
          "expr": "histogram_quantile(0.95, sum by (service_name, le) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{service_name}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "p99",
          "expr": "histogram_quantile(0.99, sum by (service_name, le) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{service_name}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "seconds",
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "panels": [],
      "title": "weather-api latency distribution",
      "type": "row"
    },
    {
      "type": "heatmap",
      "id": 7,
      "title": "weather-api latency heatmap (look for the bimodal pattern)",
      "description": "Heatmap of weather-api request duration. The bimodal pattern is the demo's headline observation: a fast horizontal band where cache_service had a hit and weather-api returned in a few ms, and a slow band where the cache missed and weather-api had to wait for cache_service to fetch from Open-Meteo. Drive 100+ requests with load/run_swarm.sh to see both bands clearly.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 15 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"weather-api\"}[1m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": {
          "axisPlacement": "left",
          "reverse": false,
          "unit": "s"
        },
        "color": {
          "mode": "scheme",
          "scheme": "Spectral",
          "steps": 64,
          "reverse": false
        },
        "cellGap": 1,
        "tooltip": { "show": true, "yHistogram": false },
        "legend": { "show": true }
      },
      "fieldConfig": {
        "defaults": { "custom": { "scaleDistribution": { "type": "linear" } } },
        "overrides": []
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 103,
      "panels": [],
      "title": "Status code mix",
      "type": "row"
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Status code mix per service",
      "description": "Stacked timeseries of HTTP response status codes per service. 200s dominate happy-path traffic; 4xx shows up when callers misuse the API (bad city name -> 404, days out of range -> 400); 5xx means upstream failures.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 25 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name, http_response_status_code) (rate(http_server_request_duration_seconds_count[1m]))",
          "legendFormat": "{{service_name}} {{http_response_status_code}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["dart-otel-demo", "demo"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Dart OTel Demo — Service Overview",
  "uid": "dart-otel-demo-service-overview",
  "version": 1,
  "weekStart": ""
}
